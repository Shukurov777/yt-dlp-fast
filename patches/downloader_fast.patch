# yt-dlp-fast patch: downloader_fast.patch
# Target file: yt_dlp/downloader/external.py
# Compatible with yt-dlp versions: 2024.03.10 – 2024.11.18
#
# Changes:
#   1. Improve aria2c default arguments (file-allocation=none, faster retries)
#   2. Add aria2c availability check with a clear warning message
#   3. Mark with yt-dlp-fast comment

--- a/yt_dlp/downloader/external.py
+++ b/yt_dlp/downloader/external.py
@@ -150,6 +150,17 @@ class Aria2cFD(ExternalFD):
     AVAILABLE_OPT = '-v'
     _SUPPORTED_FEATURES = (Features.NO_INTERRUPT,)
 
+    # yt-dlp-fast: verify aria2c is reachable before attempting download
+    @classmethod
+    def available(cls, path=None):
+        _available = super().available(path)
+        if not _available:
+            import sys
+            print(
+                '\033[1;33m[yt-dlp-fast] WARNING: aria2c not found in PATH. '
+                'Falling back to native downloader. '
+                'Install aria2c for faster downloads.\033[0m',
+                file=sys.stderr,
+            )
+        return _available
+
     def _make_cmd(self, tmpfilename, info_dict):
         cmd = [self.exe, '-c',
                '--console-log-level=warn',
@@ -157,8 +169,10 @@ class Aria2cFD(ExternalFD):
                '--summary-interval=0',
                '--file-allocation=prealloc',
+               # yt-dlp-fast: disable prealloc (faster start, works on all FS)
+               '--file-allocation=none',
                '--auto-file-renaming=false',
-              f'--retry-wait=5',

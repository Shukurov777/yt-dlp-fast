#!/usr/bin/env bash
set -euo pipefail

# yt-dlp-fast — high-performance yt-dlp wrapper
# Usage: yt-dlp-fast [--fast|--turbo|--safe|--audio|--video|--benchmark|--debug] [yt-dlp options] URL

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

CONFIG_FILE="/etc/yt-dlp-fast/yt-dlp-fast.conf"
LOG_FILE="/var/log/yt-dlp-fast/yt-dlp-fast.log"

# ── Load config if available ──────────────────────────────────────────────────
if [[ -f "${CONFIG_FILE}" ]]; then
    # shellcheck source=/dev/null
    source "${CONFIG_FILE}"
fi

# ── Log file fallback to $HOME when /var/log is not writable ─────────────────
_log_dir="$(dirname "${LOG_FILE}")"
if [[ ! -d "${_log_dir}" ]] && ! mkdir -p "${_log_dir}" 2>/dev/null; then
    LOG_FILE="${HOME}/.yt-dlp-fast/log.txt"
    mkdir -p "$(dirname "${LOG_FILE}")" 2>/dev/null || true
fi
unset _log_dir

# ── Defaults (can be overridden by config) ────────────────────────────────────
MODE="${MODE:-turbo}"
CONCURRENT_FRAGMENTS="${CONCURRENT_FRAGMENTS:-16}"
ARIA2_CONNECTIONS="${ARIA2_CONNECTIONS:-16}"
ARIA2_SPLIT="${ARIA2_SPLIT:-16}"
CHUNK_SIZE="${CHUNK_SIZE:-1M}"
SOCKET_TIMEOUT="${SOCKET_TIMEOUT:-15}"
RETRIES="${RETRIES:-10}"
FRAGMENT_RETRIES="${FRAGMENT_RETRIES:-10}"

log() {
    local log_dir
    log_dir="$(dirname "${LOG_FILE}")"
    if [[ -d "${log_dir}" ]] || mkdir -p "${log_dir}" 2>/dev/null; then
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "${LOG_FILE}" 2>/dev/null || true
    fi
}

info()  { echo -e "${GREEN}[yt-dlp-fast]${NC} $*"; }
warn()  { echo -e "${YELLOW}[yt-dlp-fast]${NC} $*"; }
error() { echo -e "${RED}[yt-dlp-fast]${NC} $*" >&2; }

# ── Node.js runtime check ─────────────────────────────────────────────────────
if ! command -v node &>/dev/null; then
    warn "Node.js is required for YouTube signature decoding. Install with: apt install nodejs"
fi

# ── Argument parsing ──────────────────────────────────────────────────────────
MODE_FLAG=""
DEBUG_MODE=false
PASSTHROUGH_ARGS=()

if [[ $# -eq 0 ]]; then
    echo "Usage: yt-dlp-fast [--fast|--turbo|--safe|--audio|--video|--benchmark|--debug] [yt-dlp-args] URL"
    exit 1
fi

# Check if first argument is a mode or debug flag
case "${1:-}" in
    --fast|--turbo|--safe|--audio|--video|--benchmark)
        MODE_FLAG="${1}"
        shift
        ;;
    --debug)
        DEBUG_MODE=true
        shift
        MODE_FLAG="--${MODE}"
        ;;
    *)
        # No mode flag; use default from config (turbo)
        MODE_FLAG="--${MODE}"
        ;;
esac

# Allow --debug immediately after a mode flag
if [[ "${1:-}" == "--debug" ]]; then
    DEBUG_MODE=true
    shift
fi

PASSTHROUGH_ARGS=("$@")

# ── Detect YouTube URL ────────────────────────────────────────────────────────
IS_YOUTUBE=false
for _arg in "${PASSTHROUGH_ARGS[@]}"; do
    if [[ "${_arg}" =~ (youtube\.com|youtu\.be) ]]; then
        IS_YOUTUBE=true
        break
    fi
done

# ── Warn about cookies-from-browser on headless servers ──────────────────────
for _arg in "${PASSTHROUGH_ARGS[@]}"; do
    if [[ "${_arg}" == "--cookies-from-browser" ]]; then
        if [[ -z "${DISPLAY:-}" && -z "${WAYLAND_DISPLAY:-}" ]]; then
            warn "cookies-from-browser may not work reliably on headless servers. Consider using --cookies <file> instead."
        fi
        break
    fi
done

# ── Check whether user already specified a format ────────────────────────────
_user_has_format=false
for _arg in "${PASSTHROUGH_ARGS[@]}"; do
    if [[ "${_arg}" == "-f" || "${_arg}" == "--format" ]]; then
        _user_has_format=true
        break
    fi
done

# ── Build yt-dlp argument arrays ──────────────────────────────────────────────

# Common aria2c turbo args
aria2c_fast_args() {
    local conns="${1:-8}" splits="${2:-8}"
    echo "aria2c:-x ${conns} -s ${splits} -k ${CHUNK_SIZE} --file-allocation=none --summary-interval=0"
}

# For YouTube, scope aria2c to http/https/dash protocols only to avoid
# interfering with format selection (prevents "Only images are available").
if [[ "${IS_YOUTUBE}" == true ]]; then
    _DOWNLOADER=(--downloader "dash,http,https:aria2c")
else
    _DOWNLOADER=(--downloader aria2c)
fi

YTDLP_ARGS=()

case "${MODE_FLAG}" in
    --fast)
        info "Mode: FAST (8 parallel connections)"
        log "Mode: fast"
        YTDLP_ARGS=(
            "${_DOWNLOADER[@]}"
            --downloader-args "$(aria2c_fast_args 8 8)"
            --concurrent-fragments 8
            --fragment-retries "${FRAGMENT_RETRIES}"
            --retries "${RETRIES}"
            --socket-timeout "${SOCKET_TIMEOUT}"
            --merge-output-format mp4
        )
        ;;
    --turbo)
        info "Mode: TURBO (16 parallel connections)"
        log "Mode: turbo"
        YTDLP_ARGS=(
            "${_DOWNLOADER[@]}"
            --downloader-args "$(aria2c_fast_args "${ARIA2_CONNECTIONS}" "${ARIA2_SPLIT}")"
            --concurrent-fragments "${CONCURRENT_FRAGMENTS}"
            --fragment-retries "${FRAGMENT_RETRIES}"
            --retries "${RETRIES}"
            --socket-timeout "${SOCKET_TIMEOUT}"
            --merge-output-format mp4
        )
        ;;
    --safe)
        info "Mode: SAFE (no aria2c, conservative settings)"
        log "Mode: safe"
        YTDLP_ARGS=(
            --fragment-retries 5
            --retries 5
            --socket-timeout 30
            --merge-output-format mp4
        )
        ;;
    --audio)
        info "Mode: AUDIO (MP3, best quality)"
        log "Mode: audio"
        YTDLP_ARGS=(
            "${_DOWNLOADER[@]}"
            --downloader-args "$(aria2c_fast_args "${ARIA2_CONNECTIONS}" "${ARIA2_SPLIT}")"
            --concurrent-fragments "${CONCURRENT_FRAGMENTS}"
            --fragment-retries "${FRAGMENT_RETRIES}"
            --retries "${RETRIES}"
            --socket-timeout "${SOCKET_TIMEOUT}"
            -x
            --audio-format mp3
            --audio-quality 0
        )
        ;;
    --video)
        info "Mode: VIDEO (bestvideo+bestaudio)"
        log "Mode: video"
        YTDLP_ARGS=(
            "${_DOWNLOADER[@]}"
            --downloader-args "$(aria2c_fast_args "${ARIA2_CONNECTIONS}" "${ARIA2_SPLIT}")"
            --concurrent-fragments "${CONCURRENT_FRAGMENTS}"
            --fragment-retries "${FRAGMENT_RETRIES}"
            --retries "${RETRIES}"
            --socket-timeout "${SOCKET_TIMEOUT}"
            -f "bestvideo+bestaudio/best"
            --merge-output-format mp4
        )
        ;;
    --benchmark)
        info "Mode: BENCHMARK"
        log "Mode: benchmark"
        if [[ ${#PASSTHROUGH_ARGS[@]} -eq 0 ]]; then
            error "Benchmark mode requires a URL argument."
            exit 1
        fi
        URL="${PASSTHROUGH_ARGS[0]}"
        BENCH_DIR="/tmp/yt-dlp-fast-bench-$$"
        mkdir -p "${BENCH_DIR}"

        run_timed() {
            local label="$1"; shift
            local start end elapsed
            start=$(date +%s%N)
            yt-dlp "$@" -o "${BENCH_DIR}/%(title)s.%(ext)s" "${URL}" \
                --no-playlist --max-filesize 50M 2>&1 | tail -5 || true
            end=$(date +%s%N)
            elapsed=$(( (end - start) / 1000000 ))
            echo -e "${GREEN}${label}${NC}: ${elapsed}ms elapsed"
            log "Benchmark ${label}: ${elapsed}ms"
        }

        echo ""
        echo -e "${YELLOW}════════════════════ BENCHMARK ════════════════════${NC}"
        echo -e "${YELLOW}URL: ${URL}${NC}"
        echo ""

        echo -e "${YELLOW}[1/3] Baseline (plain yt-dlp, safe settings)...${NC}"
        run_timed "SAFE  " \
            --fragment-retries 5 --retries 5 --socket-timeout 30 \
            --merge-output-format mp4

        echo ""
        echo -e "${YELLOW}[2/3] Fast mode (aria2c -x8)...${NC}"
        run_timed "FAST  " \
            --downloader aria2c \
            --downloader-args "$(aria2c_fast_args 8 8)" \
            --concurrent-fragments 8 \
            --fragment-retries 10 --retries 10 --socket-timeout 15 \
            --merge-output-format mp4

        echo ""
        echo -e "${YELLOW}[3/3] Turbo mode (aria2c -x16)...${NC}"
        run_timed "TURBO " \
            --downloader aria2c \
            --downloader-args "$(aria2c_fast_args 16 16)" \
            --concurrent-fragments 16 \
            --fragment-retries 10 --retries 10 --socket-timeout 15 \
            --merge-output-format mp4

        echo ""
        echo -e "${YELLOW}═══════════════════════════════════════════════════${NC}"
        echo -e "${YELLOW}NOTE: Results depend on your server, network and CDN.${NC}"
        echo -e "${YELLOW}Speedup is not guaranteed.${NC}"
        echo ""

        # Cleanup
        [[ -n "${BENCH_DIR}" && "${BENCH_DIR}" == /tmp/yt-dlp-fast-bench-* ]] && rm -rf "${BENCH_DIR}"
        exit 0
        ;;
    *)
        warn "Unknown mode '${MODE_FLAG}'. Using turbo defaults."
        log "Unknown mode ${MODE_FLAG}, falling back to turbo"
        YTDLP_ARGS=(
            "${_DOWNLOADER[@]}"
            --downloader-args "$(aria2c_fast_args "${ARIA2_CONNECTIONS}" "${ARIA2_SPLIT}")"
            --concurrent-fragments "${CONCURRENT_FRAGMENTS}"
            --fragment-retries "${FRAGMENT_RETRIES}"
            --retries "${RETRIES}"
            --socket-timeout "${SOCKET_TIMEOUT}"
            --merge-output-format mp4
        )
        ;;
esac

# ── YouTube-specific extractor args (bypass n-challenge and signature issues) ─
if [[ "${IS_YOUTUBE}" == true ]]; then
    YTDLP_ARGS+=(
        --extractor-args "youtube:player_client=android"
        --extractor-args "youtube:player_skip=webpage"
    )
    # Apply a broad-compatible format selector when the user hasn't chosen one
    # and the mode doesn't set its own format (audio/video handle their own).
    if [[ "${_user_has_format}" == false ]] && [[ "${MODE_FLAG}" != "--audio" && "${MODE_FLAG}" != "--video" ]]; then
        YTDLP_ARGS+=(--format "bv*+ba/b")
    fi
fi

# ── Debug mode args ───────────────────────────────────────────────────────────
if [[ "${DEBUG_MODE}" == true ]]; then
    YTDLP_ARGS+=(-v --print-traffic)
fi

# ── Execute yt-dlp with auto fallback ─────────────────────────────────────────
log "Executing: yt-dlp ${YTDLP_ARGS[*]} ${PASSTHROUGH_ARGS[*]}"

# Safe fallback args — no aria2c, conservative settings
_SAFE_ARGS=(
    --fragment-retries "${FRAGMENT_RETRIES}"
    --retries "${RETRIES}"
    --socket-timeout 30
    --merge-output-format mp4
)
if [[ "${IS_YOUTUBE}" == true ]]; then
    _SAFE_ARGS+=(
        --extractor-args "youtube:player_client=android"
        --extractor-args "youtube:player_skip=webpage"
    )
fi
if [[ "${DEBUG_MODE}" == true ]]; then
    _SAFE_ARGS+=(-v --print-traffic)
fi

# Run yt-dlp; show stderr in real-time via a FIFO while also capturing it to
# a temp file for error-pattern detection after the process exits.
# Using a FIFO avoids the process-substitution race condition.
_tmp_dir=$(mktemp -d)
_tmp_fifo="${_tmp_dir}/stderr.pipe"
_tmp_err="${_tmp_dir}/stderr.log"
mkfifo "${_tmp_fifo}"
# Ensure cleanup on exit or signal
trap 'rm -rf "${_tmp_dir}"' EXIT INT TERM

tee "${_tmp_err}" < "${_tmp_fifo}" >&2 &
_tee_pid=$!
set +e
yt-dlp "${YTDLP_ARGS[@]}" "${PASSTHROUGH_ARGS[@]}" 2>"${_tmp_fifo}"
_rc=$?
set -e
wait "${_tee_pid}" 2>/dev/null || true
rm -f "${_tmp_fifo}"

if [[ ${_rc} -eq 0 ]]; then
    exit 0
fi

# ── Fallback: format not available ───────────────────────────────────────────
# NOTE: Pattern depends on yt-dlp's current error messages; update if yt-dlp
# changes its wording.
if grep -qE "Requested format is not available|No video formats found" "${_tmp_err}" 2>/dev/null; then
    warn "Requested format not available. Retrying with --format best..."
    log "Format not available, retrying with --format best"

    # Place --format best after PASSTHROUGH_ARGS so it overrides any user-supplied
    # --format flag that caused the initial failure.
    _tmp_fifo="${_tmp_dir}/stderr2.pipe"
    mkfifo "${_tmp_fifo}"
    tee "${_tmp_err}" < "${_tmp_fifo}" >&2 &
    _tee_pid=$!
    set +e
    yt-dlp "${_SAFE_ARGS[@]}" "${PASSTHROUGH_ARGS[@]}" --format best 2>"${_tmp_fifo}"
    _rc=$?
    set -e
    wait "${_tee_pid}" 2>/dev/null || true
    rm -f "${_tmp_fifo}"

    if [[ ${_rc} -eq 0 ]]; then
        exit 0
    fi

    warn "Still failing. Retrying in safe mode without format override..."
    log "Retrying in safe mode"
    set +e
    yt-dlp "${_SAFE_ARGS[@]}" "${PASSTHROUGH_ARGS[@]}"
    _rc=$?
    set -e
    exit ${_rc}
fi

# ── Fallback: turbo/fast mode general failure → safe mode ────────────────────
if [[ "${MODE_FLAG}" == "--turbo" || "${MODE_FLAG}" == "--fast" ]]; then
    warn "Download failed. Retrying in safe mode..."
    log "Download failed, falling back to safe mode"
    set +e
    yt-dlp "${_SAFE_ARGS[@]}" "${PASSTHROUGH_ARGS[@]}"
    _rc=$?
    set -e
    exit ${_rc}
fi

exit ${_rc}
